# Secrets: ignore every .env variant anywhere (root, scripts/, etc.),
# but keep the committed placeholder templates.
.env*
!.env.example

# Local SQLite databases (never commit real data).
*.db
*.db-journal
prisma/dev.db
prisma/dev.db-journal

# OS / editor / misc junk and stray credentials at the repo root.
.DS_Store
*.pem
*.key
*.log

# Raw squad-fetch output (regenerated by scripts/squad-fetch/fetch-squads.js).
# The app's committed seed copy at wc2026-predictor/prisma/data/ is unaffected.
scripts/squad-fetch/data/

# graphify knowledge-graph output (generated locally, not source).
graphify-out/
.graphify/
