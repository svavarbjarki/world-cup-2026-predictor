# Copy this file to .env and fill in real values. Do not commit .env.

# SQLite database file (Prisma).
DATABASE_URL="file:./dev.db"

# Shared access password the organizer hands out. Same value for everyone.
SHARED_PASSWORD="set-a-shared-password"

# Secret used to sign auth cookies. Generate a long random string, for example:
#   openssl rand -hex 32
AUTH_SECRET="generate-a-long-random-secret"

# Organizer-only admin password, gates the /admin tools. Different from the
# shared player password above.
ADMIN_PASSWORD="set-an-admin-password"
